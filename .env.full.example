# Full environment reference for advanced deployments.
# Copy to .env when all supported settings should be visible.

# Stack, image and container identity. Keep STACK_NAME stable so the data volume
# remains <project-name>_data across updates.
STACK_NAME=no-one-survived
IMAGE_TAG=latest
CONTAINER_NAME=no-one-survived
STOP_GRACE_PERIOD=180s

# Container identity and runtime.
TZ=UTC
PUID=1000
PGID=1000
UMASK=0027
RUNTIME_DIR=/run/nos
# Leave empty to derive both paths from RUNTIME_DIR.
STATE_FILE=
CONTROL_SOCKET=
NOSCTL_TIMEOUT_SECONDS=5
HEALTHCHECK_MAX_HEARTBEAT_AGE=600

# Published and internal network settings.
HOST_BIND_ADDRESS=0.0.0.0
GAME_PORT=7777
QUERY_PORT=27015
MULTIHOME=0.0.0.0

# Prepare/update while the container starts, then wait for a UDP wake packet.
PREPARE_ON_CONTAINER_START=true
START_SERVER_ON_CONTAINER_START=false
UPDATE_ON_CONTAINER_START=true
UPDATE_ON_WAKE=false
UPDATE_INTERVAL_SECONDS=0
UPDATE_RETRY_DELAY_SECONDS=900
STEAMCMD_TIMEOUT_SECONDS=3600
VALIDATE_ON_UPDATE=false
START_ON_UPDATE_FAILURE=false

# Sleep after one hour with zero players, confirmed through Steam A2S queries.
AUTO_SLEEP_ENABLED=true
IDLE_TIMEOUT_SECONDS=3600
IDLE_CHECK_INTERVAL_SECONDS=30
MIN_UPTIME_SECONDS=900
IDLE_MIN_SUCCESSFUL_QUERIES=3
A2S_TIMEOUT_SECONDS=2
# Leave empty to select 127.0.0.1 for MULTIHOME=0.0.0.0, otherwise MULTIHOME.
A2S_QUERY_HOST=
ALLOW_LOG_ONLY_IDLE=false

# Wake when a packet reaches the game or Steam query UDP port.
WAKE_ON_GAME_PORT=true
WAKE_ON_QUERY_PORT=true
WAKE_BIND_ADDRESS=0.0.0.0
WAKE_SOURCE_POLICY=private
WAKE_ALLOWED_NETWORKS=
WAKE_PACKET_COUNT=1
WAKE_PACKET_WINDOW_SECONDS=5
WAKE_ARM_DELAY_SECONDS=5
WAKE_IGNORE_EMPTY_PACKETS=true

# Core game settings.
SERVER_NAME=No One Survived
SAVE_NAME=MainWorld
REGION=EU
MAP=Map01
MAX_PLAYERS=8
# The quick start creates and mounts a server password, so password protection is enabled.
REQUIRE_PASSWORD=true
ZOMBIES_PER_PLAYER=50
PVP=false
ZOMBIE_ATTACK=true
ZOMBIE_ATTACK_DAY=7
ATTACK_ZOMBIE_NUM=2
ZOMBIE_NUM=2
RUN_ZOMBIE_PERCENT=0.5
ZOMBIE_STRENGTH=1
SPECIAL_ZOMBIE=true
YEAR_DAYS=40
DAY_LENGTH=60
PERMADEATH=false
MATERIAL_AMOUNT=1
ITEM_SPAWN=1
VIRUS_FATALITY_RATE=0.5
NOVICE_GIFT_BAG=true
NPC_ITEM_SPAWN=1
# JSON escape hatch for settings that do not yet have a dedicated variable.
GAME_INI_OVERRIDES=
GAME_INI_OVERRIDES_FILE=

# Process recovery and compatibility.
SERVER_READY_TIMEOUT_SECONDS=300
SERVER_STOP_TIMEOUT_SECONDS=90
RESTART_ON_CRASH=true
CRASH_RESTART_DELAY_SECONDS=15
MAX_CRASH_RESTARTS=3
CRASH_RESTART_RESET_SECONDS=600
EXTRA_SERVER_ARGS=
RESET_WINEPREFIX=false
RESET_WINEPREFIX_ON_VERSION_CHANGE=true
WINEBOOT_TIMEOUT_SECONDS=600
WINEDEBUG=-all
# The bundled image is smoke-tested with its virtual display enabled.
USE_XVFB=true
FIX_PERMISSIONS=true

# Docker json-file log rotation.
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
