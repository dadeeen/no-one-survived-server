# Recommended starting configuration. Copy this file to .env.
# See docs/CONFIGURATION.md for every supported option.

# Keep STACK_NAME stable after the first deployment: it determines the data volume name.
STACK_NAME=no-one-survived
IMAGE_TAG=latest
CONTAINER_NAME=no-one-survived
STOP_GRACE_PERIOD=180s

TZ=UTC
PUID=1000
PGID=1000
# Wine uses a virtual display by default because this is the tested container path.
USE_XVFB=true

HOST_BIND_ADDRESS=0.0.0.0
GAME_PORT=7777
QUERY_PORT=27015

SERVER_NAME=No One Survived
SAVE_NAME=MainWorld
REGION=EU
MAP=Map01
MAX_PLAYERS=8
# The quick start creates and mounts a server password.
REQUIRE_PASSWORD=true

# Prepare the server, then wait for a game/query packet instead of starting immediately.
START_SERVER_ON_CONTAINER_START=false
AUTO_SLEEP_ENABLED=true
IDLE_TIMEOUT_SECONDS=3600
WAKE_SOURCE_POLICY=private
WAKE_ALLOWED_NETWORKS=

LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
