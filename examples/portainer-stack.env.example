# Recommended variables for examples/portainer-stack.yaml.
# Use portainer-stack.full.env.example with the advanced full stack.

# Keep STACK_NAME stable after the first deployment: it determines the data volume name.
STACK_NAME=no-one-survived
IMAGE_TAG=latest
CONTAINER_NAME=no-one-survived
STOP_GRACE_PERIOD=180s

SERVER_PASSWORD_PATH=/opt/games/no-one-survived/secrets/server_password.txt
ADMIN_PASSWORD_PATH=/opt/games/no-one-survived/secrets/admin_password.txt

TZ=UTC
PUID=1000
PGID=1000
UMASK=0027
USE_XVFB=true

HOST_BIND_ADDRESS=0.0.0.0
GAME_PORT=7777
QUERY_PORT=27015

SERVER_NAME=No One Survived
SAVE_NAME=MainWorld
REGION=EU
MAP=Map01
MAX_PLAYERS=8
REQUIRE_PASSWORD=true

START_SERVER_ON_CONTAINER_START=false
AUTO_SLEEP_ENABLED=true
IDLE_TIMEOUT_SECONDS=3600
WAKE_SOURCE_POLICY=private
WAKE_ALLOWED_NETWORKS=

LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
